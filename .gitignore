# Generated by Cargo
# will have compiled files and executables
/target/

# Remove Cargo.lock from version control for libraries, leave it for binaries
# https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# Build script output
/build/

# IntelliJ IDEs
.idea/

# VS Code settings
.vscode/

# Misc
*.rs.bk
*~
.env

# dependency directories
**/node_modules/

# macOS
.DS_Store

# Editor temp files
*.swp
*.swo
